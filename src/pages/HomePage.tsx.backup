import { ProductGrid } from '../components/organisms/ProductGrid';
import { Badge } from '../components/atoms/Badge';
import { Carousel } from '../components/molecules/Carousel';
import { products, categories, deals } from '../data/products';
import { useTheme } from '../hooks/useTheme';
import { useScrollAnimation } from '../hooks/useScrollAnimation';
import { Link } from 'react-router-dom';

interface HomePageProps {
  onAddToCart: (id: string) => void;
  onToggleWishlist?: (id: string) => void;
  onQuickView?: (id: string) => void;
  wishlistItems?: string[];
}

export function HomePage({ onAddToCart, onToggleWishlist, onQuickView, wishlistItems = [] }: HomePageProps) {
  const { mode } = useTheme();
  
  // Scroll animations for each section
  const heroAnim = useScrollAnimation();
  const categoriesAnim = useScrollAnimation();
  const dealsAnim = useScrollAnimation();
  const productsAnim = useScrollAnimation();
  const newArrivalsAnim = useScrollAnimation();
  const saleAnim = useScrollAnimation();
  const featuresAnim = useScrollAnimation();
  const newsletterAnim = useScrollAnimation();
  
  // Split products into chunks for carousel
  const productsPerSlide = 8;
  const productSlides = [];
  for (let i = 0; i < products.length; i += productsPerSlide) {
    productSlides.push(products.slice(i, i + productsPerSlide));
  }
  
  const newArrivals = products.filter(p => p.badge === 'New');
  const saleProducts = products.filter(p => p.badge === 'Sale');

  return (
    <div className="space-y-24 relative overflow-hidden">
      {/* Animated Background Elements */}
      <div className="fixed inset-0 pointer-events-none overflow-hidden">
        <div 
          className="absolute top-20 right-20 w-96 h-96 rounded-full blur-3xl opacity-20"
          style={{
            background: mode === 'light' 
              ? 'radial-gradient(circle, rgba(73,80,87,0.3) 0%, transparent 70%)'
              : 'radial-gradient(circle, rgba(139,92,246,0.3) 0%, transparent 70%)',
            animation: 'float 8s ease-in-out infinite'
          }}
        />
        <div 
          className="absolute bottom-40 left-20 w-96 h-96 rounded-full blur-3xl opacity-20"
          style={{
            background: mode === 'light'
              ? 'radial-gradient(circle, rgba(168,85,247,0.3) 0%, transparent 70%)'
              : 'radial-gradient(circle, rgba(236,72,153,0.3) 0%, transparent 70%)',
            animation: 'float 10s ease-in-out infinite reverse'
          }}
        />
      </div>

      {/* Hero Section - Ultra Modern Design */}
      <section 
        ref={heroAnim.ref}
        className={`relative min-h-screen flex items-center fade-in-up ${heroAnim.isVisible ? 'visible' : ''}`}
      >
        <div className="max-w-7xl mx-auto px-6 py-12">
          <div className="grid lg:grid-cols-2 gap-20 items-center">
            {/* Left Content */}
            <div className="space-y-10 z-10">
              {/* Badge */}
              <div 
                className={`inline-flex items-center gap-3 glass rounded-full px-8 py-4 fade-in-left stagger-1 ${heroAnim.isVisible ? 'visible' : ''}`}
                style={{
                  background: mode === 'light'
                    ? 'linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 250, 252, 0.9) 100%)'
                    : 'linear-gradient(135deg, rgba(139, 92, 246, 0.2) 0%, rgba(236, 72, 153, 0.2) 100%)',
                  backdropFilter: 'blur(20px)',
                  border: mode === 'light' 
                    ? '2px solid rgba(102, 126, 234, 0.2)'
                    : '2px solid rgba(139, 92, 246, 0.3)',
                  boxShadow: mode === 'light'
                    ? '0 8px 32px rgba(102, 126, 234, 0.15)'
                    : '0 8px 32px rgba(139, 92, 246, 0.3)'
                }}
              >
                <span className="text-2xl">✨</span>
                <span 
                  className="text-base font-black tracking-wide"
                  style={{ 
                    background: mode === 'light'
                      ? 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'
                      : 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)',
                    WebkitBackgroundClip: 'text',
                    WebkitTextFillColor: 'transparent'
                  }}
                >
                  NEW COLLECTION 2026
                </span>
              </div>
              
              {/* Main Heading */}
              <h1 
                className={`text-7xl sm:text-8xl lg:text-9xl font-black leading-[0.95] fade-in-left stagger-2 ${heroAnim.isVisible ? 'visible' : ''}`}
                style={{ 
                  color: mode === 'light' ? '#0f172a' : '#ffffff',
                  letterSpacing: '-0.02em'
                }}
              >
                Discover
                <span 
                  className="block mt-2"
                  style={{ 
                    background: mode === 'light'
                      ? 'linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%)'
                      : 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 50%, #f472b6 100%)',
                    WebkitBackgroundClip: 'text',
                    WebkitTextFillColor: 'transparent',
                    animation: 'gradient 5s ease infinite',
                    backgroundSize: '200% 200%',
                    textShadow: mode === 'dark' ? '0 0 80px rgba(139, 92, 246, 0.5)' : 'none'
                  }}
                >
                  Amazing
                </span>
                <span className="block mt-2">Products</span>
              </h1>
              
              {/* Description */}
              <p 
                className={`text-2xl lg:text-3xl leading-relaxed font-medium fade-in-left stagger-3 ${heroAnim.isVisible ? 'visible' : ''}`}
                style={{ color: mode === 'light' ? '#475569' : '#cbd5e1' }}
              >
                Experience the future of shopping with our cutting-edge collection. 
                <span 
                  className="block mt-2 font-black"
                  style={{ 
                    background: mode === 'light'
                      ? 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)'
                      : 'linear-gradient(135deg, #ec4899 0%, #f472b6 100%)',
                    WebkitBackgroundClip: 'text',
                    WebkitTextFillColor: 'transparent'
                  }}
                >
                  Up to 50% off on premium items.
                </span>
              </p>
              
              {/* CTA Buttons */}
              <div className={`flex flex-wrap gap-5 fade-in-left stagger-4 ${heroAnim.isVisible ? 'visible' : ''}`}>
                <button
                  className="group relative px-12 py-6 text-xl font-black rounded-2xl overflow-hidden transition-all duration-500 hover:scale-105 hover:shadow-2xl"
                  style={{
                    background: mode === 'light'
                      ? 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'
                      : 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)',
                    color: '#ffffff',
                    boxShadow: mode === 'light'
                      ? '0 20px 60px rgba(102, 126, 234, 0.5)'
                      : '0 20px 60px rgba(139, 92, 246, 0.5)'
                  }}
                >
                  <span className="relative z-10 flex items-center gap-3">
                    <span className="text-2xl">🛍️</span>
                    Shop Now
                  </span>
                  <div 
                    className="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                    style={{
                      background: mode === 'light'
                        ? 'linear-gradient(135deg, #764ba2 0%, #667eea 100%)'
                        : 'linear-gradient(135deg, #ec4899 0%, #8b5cf6 100%)'
                    }}
                  />
                </button>
                <button
                  className="group px-12 py-6 text-xl font-black rounded-2xl transition-all duration-500 hover:scale-105 hover:shadow-2xl relative overflow-hidden"
                  style={{
                    background: mode === 'light'
                      ? 'rgba(255, 255, 255, 0.9)'
                      : 'rgba(26, 34, 53, 0.9)',
                    backdropFilter: 'blur(20px)',
                    border: mode === 'light'
                      ? '3px solid rgba(102, 126, 234, 0.3)'
                      : '3px solid rgba(139, 92, 246, 0.5)',
                    color: mode === 'light' ? '#667eea' : '#a78bfa'
                  }}
                >
                  <span className="relative z-10 flex items-center gap-2">
                    Learn More
                    <svg className="w-6 h-6 group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={3} d="M13 7l5 5m0 0l-5 5m5-5H6" />
                    </svg>
                  </span>
                </button>
              </div>
              
              {/* Stats */}
              <div className={`grid grid-cols-3 gap-6 pt-12 fade-in-up stagger-4 ${heroAnim.isVisible ? 'visible' : ''}`}>
                {[
                  { value: '10K+', label: 'Products', icon: '📦' },
                  { value: '50K+', label: 'Customers', icon: '👥' },
                  { value: '4.9★', label: 'Rating', icon: '⭐' }
                ].map((stat, index) => (
                  <div
                    key={index}
                    className="group glass rounded-3xl p-8 text-center hover:scale-110 transition-all duration-500 cursor-pointer"
                    style={{
                      background: mode === 'light'
                        ? 'linear-gradient(135deg, rgba(255, 255, 255, 0.8) 0%, rgba(248, 250, 252, 0.8) 100%)'
                        : 'linear-gradient(135deg, rgba(30, 41, 59, 0.8) 0%, rgba(15, 23, 42, 0.8) 100%)',
                      backdropFilter: 'blur(20px)',
                      border: mode === 'light'
                        ? '2px solid rgba(0, 0, 0, 0.05)'
                        : '2px solid rgba(255, 255, 255, 0.1)',
                      boxShadow: mode === 'light'
                        ? '0 10px 40px rgba(0, 0, 0, 0.08)'
                        : '0 10px 40px rgba(139, 92, 246, 0.2)'
                    }}
                  >
                    <div className="text-3xl mb-3 group-hover:scale-125 transition-transform duration-300">
                      {stat.icon}
                    </div>
                    <div 
                      className="text-5xl font-black mb-2 group-hover:scale-110 transition-transform duration-300"
                      style={{ 
                        background: mode === 'light'
                          ? 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'
                          : 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)',
                        WebkitBackgroundClip: 'text',
                        WebkitTextFillColor: 'transparent'
                      }}
                    >
                      {stat.value}
                    </div>
                    <div 
                      className="text-sm font-bold uppercase tracking-wider"
                      style={{ color: mode === 'light' ? '#64748b' : '#94a3b8' }}
                    >
                      {stat.label}
                    </div>
                  </div>
                ))}
              </div>
            </div>
            
            {/* Right - Floating Product Cards with 3D Effect */}
            <div className="hidden lg:block relative h-[700px]">
              {/* Glow Effect */}
              <div 
                className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full blur-3xl opacity-30"
                style={{
                  background: mode === 'light'
                    ? 'radial-gradient(circle, rgba(102, 126, 234, 0.4) 0%, transparent 70%)'
                    : 'radial-gradient(circle, rgba(139, 92, 246, 0.6) 0%, transparent 70%)',
                  animation: 'pulse 4s ease-in-out infinite'
                }}
              />
              
              {[
                { 
                  img: 'https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400&h=400&fit=crop',
                  title: 'Headphones',
                  price: '$199.99',
                  position: 'top-0 right-0',
                  delay: '0s',
                  rotation: 'rotate-3'
                },
                {
                  img: 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400&h=400&fit=crop',
                  title: 'Smart Watch',
                  price: '$299.99',
                  position: 'bottom-0 left-0',
                  delay: '2s',
                  rotation: '-rotate-3'
                },
                {
                  img: 'https://images.unsplash.com/photo-1572635196237-14b3f281503f?w=400&h=400&fit=crop',
                  title: 'Sunglasses',
                  price: '$149.99',
                  position: 'top-1/3 left-1/4',
                  delay: '4s',
                  rotation: 'rotate-6'
                }
              ].map((product, index) => (
                <div
                  key={index}
                  className={`absolute w-80 glass rounded-3xl p-6 shadow-2xl hover:scale-110 transition-all duration-500 cursor-pointer scale-in stagger-${index + 1} ${heroAnim.isVisible ? 'visible' : ''} ${product.position} ${product.rotation} group`}
                  style={{
                    background: mode === 'light'
                      ? 'linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 250, 252, 0.95) 100%)'
                      : 'linear-gradient(135deg, rgba(30, 41, 59, 0.95) 0%, rgba(15, 23, 42, 0.95) 100%)',
                    backdropFilter: 'blur(30px)',
                    border: mode === 'light'
                      ? '2px solid rgba(102, 126, 234, 0.2)'
                      : '2px solid rgba(139, 92, 246, 0.3)',
                    animation: `float 6s ease-in-out infinite`,
                    animationDelay: product.delay,
                    boxShadow: mode === 'light'
                      ? '0 20px 60px rgba(0, 0, 0, 0.15)'
                      : '0 20px 60px rgba(139, 92, 246, 0.4)'
                  }}
                >
                  {/* Product Image */}
                  <div className="relative overflow-hidden rounded-2xl mb-5">
                    <img 
                      src={product.img}
                      alt={product.title}
                      className="rounded-2xl w-full h-56 object-cover group-hover:scale-110 transition-transform duration-700"
                    />
                    <div 
                      className="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
                      style={{
                        background: mode === 'light'
                          ? 'linear-gradient(135deg, rgba(102, 126, 234, 0.3) 0%, rgba(118, 75, 162, 0.3) 100%)'
                          : 'linear-gradient(135deg, rgba(139, 92, 246, 0.4) 0%, rgba(236, 72, 153, 0.4) 100%)'
                      }}
                    />
                  </div>
                  
                  {/* Product Info */}
                  <div 
                    className="font-black text-xl mb-3"
                    style={{ color: mode === 'light' ? '#0f172a' : '#ffffff' }}
                  >
                    {product.title}
                  </div>
                  <div 
                    className="text-3xl font-black"
                    style={{ 
                      background: mode === 'light'
                        ? 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'
                        : 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)',
                      WebkitBackgroundClip: 'text',
                      WebkitTextFillColor: 'transparent'
                    }}
                  >
                    {product.price}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* Categories Carousel */}
      <section 
        ref={categoriesAnim.ref}
        className={`relative fade-in-up ${categoriesAnim.isVisible ? 'visible' : ''}`}
      >
        <div className="max-w-7xl mx-auto px-6">
          <div className="flex items-center justify-between mb-12">
            <div>
              <h2 
                className="text-5xl font-black mb-3"
                style={{ color: mode === 'light' ? '#0f172a' : '#ffffff' }}
              >
                Shop by Category
              </h2>
              <p 
                className="text-xl"
                style={{ color: mode === 'light' ? '#64748b' : '#94a3b8' }}
              >
                Explore our diverse collection
              </p>
            </div>
          </div>
          
          {/* Carousel with partial view */}
          <div className="relative">
            <Carousel autoPlay={false} interval={5000} peekAmount={10}>
              {(() => {
                const categoriesPerSlide = 6; // Show 6 categories per slide
                const slides = [];
                for (let i = 0; i < categories.length; i += categoriesPerSlide) {
                  slides.push(categories.slice(i, i + categoriesPerSlide));
                }
                return slides.map((slideCategories, slideIndex) => (
                  <div key={slideIndex}>
                    <div className="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6">
                      {slideCategories.map((category, index) => (
                        <Link
                          key={category.id}
                          to={`/categories/${category.id}`}
                          className={`group relative p-8 rounded-3xl transition-all duration-500 text-center hover:scale-110 scale-in stagger-${index + 1} ${categoriesAnim.isVisible ? 'visible' : ''}`}
                          style={{
                            background: mode === 'light'
                              ? 'rgba(255, 255, 255, 0.7)'
                              : 'rgba(26, 34, 53, 0.7)',
                            backdropFilter: 'blur(20px)',
                            border: mode === 'light'
                              ? '1px solid rgba(0, 0, 0, 0.1)'
                              : '1px solid rgba(255, 255, 255, 0.1)',
                            boxShadow: '0 8px 32px rgba(0, 0, 0, 0.1)'
                          }}
                        >
                          <div 
                            className="w-20 h-20 rounded-2xl flex items-center justify-center mx-auto mb-5 group-hover:scale-110 group-hover:rotate-12 transition-all duration-300"
                            style={{
                              background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                              boxShadow: '0 10px 30px rgba(102, 126, 234, 0.4)'
                            }}
                          >
                            <svg className="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                            </svg>
                          </div>
                          <h3 
                            className="font-black text-lg mb-2"
                            style={{ color: mode === 'light' ? '#0f172a' : '#ffffff' }}
                          >
                            {category.name}
                          </h3>
                          <p 
                            className="text-sm font-medium"
                            style={{ color: mode === 'light' ? '#64748b' : '#94a3b8' }}
                          >
                            {category.count} items
                          </p>
                        </Link>
                      ))}
                    </div>
                  </div>
                ));
              })()}
            </Carousel>
          </div>
        </div>
      </section>

      {/* Hot Deals Carousel */}
      <section 
        ref={dealsAnim.ref}
        className={`relative fade-in-up ${dealsAnim.isVisible ? 'visible' : ''}`}
      >
        <div className="max-w-7xl mx-auto px-6">
          <div className="flex items-center justify-between mb-12">
            <div>
              <h2 
                className="text-5xl font-black mb-3"
                style={{ color: mode === 'light' ? '#0f172a' : '#ffffff' }}
              >
                🔥 Hot Deals
              </h2>
              <p 
                className="text-xl"
                style={{ color: mode === 'light' ? '#64748b' : '#94a3b8' }}
              >
                Limited time offers you can't miss
              </p>
            </div>
            <Badge variant="error" className="glow-accent text-lg px-6 py-3">Ending Soon</Badge>
          </div>
          
          <Carousel autoPlay interval={4000} peekAmount={10}>
            {deals.map((deal) => (
              <div
                key={deal.id}
                className="group relative rounded-3xl overflow-hidden h-96 cursor-pointer mx-2"
                style={{
                  boxShadow: '0 20px 60px rgba(0, 0, 0, 0.3)'
                }}
              >
                <img
                  src={deal.image}
                  alt={deal.title}
                  className="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                />
                <div className="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent"></div>
                <div className="absolute inset-0 flex flex-col justify-end p-10">
                  <Badge variant="error" className="w-fit mb-6 text-xl px-6 py-3 glow-accent font-black">
                    {deal.discount}
                  </Badge>
                  <h3 className="text-5xl font-black text-white mb-6 drop-shadow-lg">{deal.title}</h3>
                  <div className="flex items-center gap-6">
                    <button
                      className="px-8 py-4 text-lg font-bold rounded-2xl transition-all duration-300 hover:scale-105"
                      style={{
                        background: 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)',
                        color: '#ffffff',
                        boxShadow: '0 10px 40px rgba(102, 126, 234, 0.6)'
                      }}
                    >
                      Shop Now
                    </button>
                    <div className="text-white/90 text-lg font-medium">
                      ⏰ Ends {new Date(deal.endDate).toLocaleDateString()}
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </Carousel>
        </div>
      </section>

      {/* All Products Carousel */}
      <section 
        ref={productsAnim.ref}
        className={`relative fade-in-up ${productsAnim.isVisible ? 'visible' : ''}`}
      >
        <div className="max-w-7xl mx-auto px-6">
          <div className="flex items-center justify-between mb-12">
            <div>
              <h2 
                className="text-5xl font-black mb-3"
                style={{ color: mode === 'light' ? '#0f172a' : '#ffffff' }}
              >
                ✨ All Products
              </h2>
              <p 
                className="text-xl"
                style={{ color: mode === 'light' ? '#64748b' : '#94a3b8' }}
              >
                Browse through {products.length} amazing products
              </p>
            </div>
            <Badge variant="info" className="text-lg px-6 py-3">{productSlides.length} Collections</Badge>
          </div>
          
          <Carousel autoPlay={false} interval={6000} peekAmount={10}>
            {productSlides.map((slideProducts, index) => (
              <div key={index}>
                <ProductGrid
                  title=""
                  products={slideProducts}
                  onAddToCart={onAddToCart}
                  onQuickView={onQuickView}
                  onToggleWishlist={onToggleWishlist}
                  wishlistItems={wishlistItems}
                />
              </div>
            ))}
          </Carousel>
        </div>
      </section>

      {/* New Arrivals Carousel */}
      {newArrivals.length > 0 && (
        <section 
          ref={newArrivalsAnim.ref}
          className={`relative fade-in-up ${newArrivalsAnim.isVisible ? 'visible' : ''}`}
        >
          <div className="max-w-7xl mx-auto px-6">
            <div className="flex items-center justify-between mb-12">
              <div>
                <h2 
                  className="text-5xl font-black mb-3"
                  style={{ color: mode === 'light' ? '#0f172a' : '#ffffff' }}
                >
                  🆕 New Arrivals
                </h2>
                <p 
                  className="text-xl"
                  style={{ color: mode === 'light' ? '#64748b' : '#94a3b8' }}
                >
                  Just landed - {newArrivals.length} fresh products
                </p>
              </div>
              <Badge variant="success" className="text-lg px-6 py-3">Just Landed</Badge>
            </div>
            
            <Carousel autoPlay={false} interval={5000}>
              {(() => {
                const slides = [];
                for (let i = 0; i < newArrivals.length; i += 4) {
                  slides.push(newArrivals.slice(i, i + 4));
                }
                return slides.map((slideProducts, index) => (
                  <div key={index}>
                    <ProductGrid
                      title=""
                      products={slideProducts}
                      onAddToCart={onAddToCart}
                      onQuickView={onQuickView}
                      onToggleWishlist={onToggleWishlist}
                      wishlistItems={wishlistItems}
                    />
                  </div>
                ));
              })()}
            </Carousel>
          </div>
        </section>
      )}

      {/* Flash Sale Section */}
      {saleProducts.length > 0 && (
        <section 
          ref={saleAnim.ref}
          className={`relative rounded-3xl overflow-hidden mx-6 fade-in-up ${saleAnim.isVisible ? 'visible' : ''}`}
          style={{
            background: 'linear-gradient(135deg, #f093fb 0%, #f5576c 100%)',
            boxShadow: '0 20px 60px rgba(245, 87, 108, 0.4)'
          }}
        >
          <div className="absolute inset-0 opacity-10">
            <div className="absolute inset-0" style={{
              backgroundImage: 'radial-gradient(circle, white 1px, transparent 1px)',
              backgroundSize: '50px 50px'
            }}></div>
          </div>
          <div className="relative z-10 p-16 text-center text-white">
            <Badge variant="error" className="mb-6 text-xl px-8 py-4 font-black">Limited Time</Badge>
            <h2 className="text-6xl font-black mb-6 drop-shadow-lg">💥 Flash Sale</h2>
            <p className="text-2xl mb-12 opacity-90 font-medium">Up to 70% off on selected items - {saleProducts.length} deals</p>
          </div>
          <div className="relative z-10 px-6 pb-16">
            <Carousel autoPlay={false} interval={5000}>
              {(() => {
                const slides = [];
                for (let i = 0; i < saleProducts.length; i += 4) {
                  slides.push(saleProducts.slice(i, i + 4));
                }
                return slides.map((slideProducts, index) => (
                  <div key={index}>
                    <ProductGrid
                      title=""
                      products={slideProducts}
                      onAddToCart={onAddToCart}
                      onQuickView={onQuickView}
                      onToggleWishlist={onToggleWishlist}
                      wishlistItems={wishlistItems}
                    />
                  </div>
                ));
              })()}
            </Carousel>
          </div>
        </section>
      )}

      {/* Features Section */}
      <section 
        ref={featuresAnim.ref}
        className={`relative fade-in-up ${featuresAnim.isVisible ? 'visible' : ''}`}
      >
        <div className="max-w-7xl mx-auto px-6">
          <h2 
            className="text-5xl font-black text-center mb-16"
            style={{ color: mode === 'light' ? '#0f172a' : '#ffffff' }}
          >
            Why Shop With Us?
          </h2>
          <div className="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {[
              { icon: '🚚', title: 'Free Shipping', desc: 'On orders over $100', gradient: 'from-blue-500 to-cyan-500' },
              { icon: '✅', title: 'Quality Guarantee', desc: '100% authentic products', gradient: 'from-green-500 to-emerald-500' },
              { icon: '↩️', title: 'Easy Returns', desc: '30-day return policy', gradient: 'from-orange-500 to-red-500' },
              { icon: '💬', title: '24/7 Support', desc: 'Always here to help', gradient: 'from-purple-500 to-pink-500' },
            ].map((feature, index) => (
              <div
                key={index}
                className={`group relative rounded-3xl p-10 text-center hover:scale-105 transition-all duration-500 scale-in stagger-${index + 1} ${featuresAnim.isVisible ? 'visible' : ''}`}
                style={{
                  background: mode === 'light'
                    ? 'rgba(255, 255, 255, 0.7)'
                    : 'rgba(26, 34, 53, 0.7)',
                  backdropFilter: 'blur(20px)',
                  border: mode === 'light'
                    ? '1px solid rgba(0, 0, 0, 0.1)'
                    : '1px solid rgba(255, 255, 255, 0.1)',
                  boxShadow: '0 8px 32px rgba(0, 0, 0, 0.1)'
                }}
              >
                <div 
                  className={`w-24 h-24 bg-gradient-to-br ${feature.gradient} rounded-3xl flex items-center justify-center mx-auto mb-8 text-5xl group-hover:scale-110 group-hover:rotate-12 transition-all duration-300`}
                  style={{
                    boxShadow: '0 10px 40px rgba(0, 0, 0, 0.2)'
                  }}
                >
                  {feature.icon}
                </div>
                <h3 
                  className="text-2xl font-black mb-4"
                  style={{ color: mode === 'light' ? '#0f172a' : '#ffffff' }}
                >
                  {feature.title}
                </h3>
                <p 
                  className="text-lg"
                  style={{ color: mode === 'light' ? '#64748b' : '#94a3b8' }}
                >
                  {feature.desc}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Newsletter Section */}
      <section 
        ref={newsletterAnim.ref}
        className={`relative mx-6 rounded-3xl overflow-hidden fade-in-up ${newsletterAnim.isVisible ? 'visible' : ''}`}
        style={{
          background: mode === 'light'
            ? 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'
            : 'linear-gradient(135deg, #8b5cf6 0%, #ec4899 100%)',
          boxShadow: mode === 'light'
            ? '0 20px 60px rgba(102, 126, 234, 0.4)'
            : '0 20px 60px rgba(139, 92, 246, 0.4)'
        }}
      >
        <div className="absolute inset-0 opacity-10">
          <div className="absolute inset-0" style={{
            backgroundImage: 'radial-gradient(circle, white 1px, transparent 1px)',
            backgroundSize: '50px 50px'
          }}></div>
        </div>
        <div className="relative z-10 p-16 text-center">
          <h2 className="text-5xl font-black mb-6 text-white drop-shadow-lg">
            📧 Subscribe to Our Newsletter
          </h2>
          <p className="text-2xl mb-12 text-white/90 font-medium">
            Get exclusive deals and updates delivered to your inbox
          </p>
          <div className="max-w-2xl mx-auto flex gap-4">
            <input
              type="email"
              placeholder="Enter your email"
              className="flex-1 px-8 py-5 rounded-2xl text-lg font-medium focus:outline-none focus:ring-4 focus:ring-white/50 transition-all"
              style={{
                background: 'rgba(255, 255, 255, 0.9)',
                backdropFilter: 'blur(20px)',
                color: '#0f172a',
                border: '2px solid rgba(255, 255, 255, 0.3)'
              }}
            />
            <button
              className="px-10 py-5 text-lg font-black rounded-2xl transition-all duration-300 hover:scale-105"
              style={{
                background: '#ffffff',
                color: '#667eea',
                boxShadow: '0 10px 40px rgba(255, 255, 255, 0.3)'
              }}
            >
              Subscribe
            </button>
          </div>
        </div>
      </section>
    </div>
  );
}
